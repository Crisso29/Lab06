                "exec": [
                  "pm.test(\"TC-009: Status code es 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Criterio TC-009: resultados aproximados (música andina) O cero resultados — ambos válidos\r",
                  "pm.test(\"TC-009: Retorna resultados aproximados O cero resultados (ambos válidos)\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    const items = jsonData.tracks.items;\r",
                  "    // No falla en ningún escenario: el criterio acepta cualquiera de las dos opciones\r",
                  "    pm.expect(items.length).to.be.at.least(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC-009: Si hay resultados, están relacionados a la región buscada\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    const items = jsonData.tracks.items;\r",
                  "    if (items.length > 0) {\r",
                  "        const contenido = items.map(t => \r",
                  "            t.name + ' ' + t.artists.map(a => a.name).join(' ')\r",
                  "        ).join(' ').toLowerCase();\r",
                  "        pm.expect(contenido).to.include('ayacucho');\r",

                  "// Se interpreta como rechazo CONTROLADO (no es un error de aplicación, es validación\r",
                  "// de entrada funcionando correctamente) → PASS con observación.\r",
                  "// Recomendación: reescribir el criterio de aceptación para incluir explícitamente\r",
                  "// \"o rechazo controlado con código 4xx y mensaje claro\" como salida válida.\r",
                  "\r",
                  "pm.test(\"TC-010: No es un error de servidor (5xx) — sería un fallo real de aplicación\", function () {\r",
                  "    pm.expect(pm.response.code).to.not.be.within(500, 599);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC-010: Rechazo controlado y explícito (400) con mensaje claro\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.error).to.exist;\r",
                  "    pm.expect(jsonData.error.message).to.be.a('string').and.not.empty;\r",
                  "});"

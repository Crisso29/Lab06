        {
          "name": "TC-007: Búsqueda válida Dua Lipa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"TC-007: Status code es 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC-007: La respuesta contiene artistas\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.artists).to.exist;\r",
                  "    pm.expect(jsonData.artists.items).to.be.an('array');\r",
                  "    pm.expect(jsonData.artists.items.length).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC-007: Dua Lipa aparece como resultado más relevante\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    const masRelevante = jsonData.artists.items[0];\r",
                  "    pm.expect(masRelevante.name).to.eql(\"Dua Lipa\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC-007: El artista tiene estructura válida\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    const artista = jsonData.artists.items[0];\r",
                  "    pm.expect(artista).to.have.property('id');\r",
                  "    pm.expect(artista).to.have.property('uri');\r",
                  "    pm.expect(artista.type).to.eql('artist');\r",
